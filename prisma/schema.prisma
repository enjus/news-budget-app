generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// All enum-like fields use String with validation enforced at the API layer via Zod.
// Valid values documented in src/lib/validations.ts.
// This keeps the schema DB-agnostic and migration-friendly (sqlite → postgresql).

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // AppRole: ADMIN | EDITOR | VIEWER
  appRole      String   @default("EDITOR")
  personId     String?  @unique
  person       Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([appRole])
}

model Person {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  // PersonRole: REPORTER | EDITOR | PHOTOGRAPHER | GRAPHIC_DESIGNER | PUBLICATION_DESIGNER | OTHER
  defaultRole String   @default("OTHER")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user              User?
  assignments       StoryAssignment[]
  visuals           Visual[]
  videoAssignments  VideoAssignment[]
  teamMemberships   TeamMember[]
  mediaRequests     MediaRequest[]   @relation("mediaRequestedBy")
  mediaAssignments  MediaAssignment[]
  calendarToken     String?          @unique
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  id       String   @id @default(cuid())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  // TeamRole: EDITOR | MEMBER
  role     String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([teamId, personId])
}

model Story {
  id               String   @id @default(cuid())
  slug             String
  budgetLine       String
  isEnterprise     Boolean  @default(false)
  // StoryStatus: DRAFT | PUBLISHED_ITERATING | PUBLISHED_FINAL | SHELVED
  status           String   @default("DRAFT")
  onlinePubDate    DateTime?
  onlinePubDateTBD Boolean  @default(true)
  printPubDate     DateTime?
  printPubDateTBD  Boolean  @default(true)
  notes            String?
  wordCount        Int?
  notifyTeam       Boolean  @default(false)
  aiContributed    Boolean  @default(false)
  sortOrder        Int      @default(0)
  shelvedAt        DateTime? // set when status → SHELVED, cleared otherwise
  postUrl          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignments   StoryAssignment[]
  visuals       Visual[]
  videos        Video[]
  mediaRequests MediaRequest[]

  @@index([status])
  @@index([isEnterprise])
  @@index([onlinePubDate])
  @@index([printPubDate])
  @@index([status, onlinePubDate])
  @@index([isEnterprise, status])
}

model StoryAssignment {
  id       String   @id @default(cuid())
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId  String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  // AssignmentRole: REPORTER | EDITOR | OTHER
  role     String
  createdAt DateTime @default(now())

  @@unique([storyId, personId, role])
}

model Visual {
  id          String   @id @default(cuid())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId     String
  // VisualType: PHOTO | GRAPHIC
  type        String
  description String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  personId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Videos can be standalone (storyId = null) or attached to a story.
model Video {
  id               String   @id @default(cuid())
  slug             String
  budgetLine       String
  isEnterprise     Boolean  @default(false)
  // StoryStatus: DRAFT | PUBLISHED_ITERATING | PUBLISHED_FINAL | SHELVED
  status           String   @default("DRAFT")
  storyId          String?
  story            Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  onlinePubDate    DateTime?
  onlinePubDateTBD Boolean  @default(true)
  notes            String?
  notifyTeam       Boolean  @default(false)
  aiContributed    Boolean  @default(false)
  sortOrder        Int      @default(0)
  shelvedAt        DateTime? // set when status → SHELVED, cleared otherwise
  youtubeUrl       String?
  reelsUrl         String?
  tiktokUrl        String?
  otherUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignments VideoAssignment[]

  @@index([status])
  @@index([isEnterprise])
  @@index([onlinePubDate])
  @@index([status, onlinePubDate])
  @@index([isEnterprise, status])
}

model VideoAssignment {
  id       String   @id @default(cuid())
  video    Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId  String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  // AssignmentRole: REPORTER | EDITOR | OTHER
  role     String
  createdAt DateTime @default(now())

  @@unique([videoId, personId, role])
}

model MediaRequest {
  id             String   @id @default(cuid())
  title          String
  // MediaRequestType: PHOTO | VIDEO | PHOTO_VIDEO | GRAPHIC | MAP
  type           String
  // MediaRequestStatus: REQUESTED | ASSIGNED | IN_PROGRESS | COMPLETED | DELIVERED | DECLINED | CANCELED
  status         String   @default("REQUESTED")
  // MediaRequestPriority: NORMAL | URGENT
  priority       String   @default("NORMAL")
  storyId        String?
  story          Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  requestedById  String
  requestedBy    Person   @relation("mediaRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  eventDateTime  DateTime?
  location       String?
  description    String?
  notes          String?
  deadline       DateTime?
  declineReason  String?
  archived       Boolean  @default(false)
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    MediaAssignment[]
  dataLinks      DataLink[]

  @@index([status])
  @@index([type])
  @@index([storyId])
  @@index([requestedById])
  @@index([status, type])
  @@index([eventDateTime])
  @@index([archived])
}

model MediaAssignment {
  id             String   @id @default(cuid())
  mediaRequest   MediaRequest @relation(fields: [mediaRequestId], references: [id], onDelete: Cascade)
  mediaRequestId String
  person         Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId       String
  // MediaAssignmentRole: PHOTOGRAPHER | VIDEOGRAPHER | GRAPHIC_DESIGNER | OTHER
  role           String
  createdAt      DateTime @default(now())

  @@unique([mediaRequestId, personId, role])
}

model DataLink {
  id             String   @id @default(cuid())
  mediaRequest   MediaRequest @relation(fields: [mediaRequestId], references: [id], onDelete: Cascade)
  mediaRequestId String
  url            String
  label          String?
  createdAt      DateTime @default(now())
}
