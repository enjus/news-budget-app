# Copy this file to .env and fill in your values.

# PostgreSQL connection string (e.g. Neon, Supabase, Railway, or local Postgres)
# connection_limit and pool_timeout prevent Prisma from exhausting the DB connection pool under load
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connection_limit=10&pool_timeout=15"

# NextAuth — set NEXTAUTH_URL to your app's base URL
NEXTAUTH_URL="http://localhost:3000"

# Generate a secret with: openssl rand -hex 32
NEXTAUTH_SECRET="your-secret-here"

# Azure AD SSO (optional — omit AZURE_AD_CLIENT_ID to disable SSO)
# See README or CLAUDE.md for Azure Portal setup instructions.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""
# Object ID of the Azure AD security group whose members can sign in.
# If set, only members of this group are allowed; others are rejected.
# If omitted, any user in the tenant can sign in via SSO.
AZURE_AD_ALLOWED_GROUP_ID=""
